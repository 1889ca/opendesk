# Contract: contracts/config/rules.md
# OpenDesk production environment variables
# Copy to .env and fill in all values before deploying.
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env up -d

# --- Postgres ---
PG_DATABASE=opendesk
PG_USER=opendesk
PG_PASSWORD=CHANGE_ME_pg_strong_password

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_strong_password

# --- MinIO / S3 ---
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key
S3_BUCKET=opendesk

# --- Auth ---
AUTH_MODE=oidc
SESSION_SECRET=CHANGE_ME_64_char_random_string
OIDC_ISSUER=https://your-idp.example.com
OIDC_CLIENT_ID=CHANGE_ME_client_id
OIDC_CLIENT_SECRET=CHANGE_ME_client_secret

# --- Nginx (optional, defaults shown) ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
