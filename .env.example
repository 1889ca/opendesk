# OpenDesk development environment
# Copy to .env and adjust as needed: cp .env.example .env

# Auth: "dev" bypasses OIDC (use for local development)
AUTH_MODE=dev

# PostgreSQL (defaults match docker-compose.yml)
# PG_HOST=localhost
# PG_PORT=5433
# PG_DATABASE=opendesk
# PG_USER=opendesk
# PG_PASSWORD=opendesk_dev

# S3 / MinIO (defaults match docker-compose.yml)
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=opendesk
# S3_SECRET_KEY=opendesk_dev
# S3_BUCKET=opendesk

# Redis
# REDIS_URL=redis://localhost:6379

# Collabora (for .docx/.odt import/export)
# COLLABORA_URL=http://localhost:9980

# Server
# PORT=3000
