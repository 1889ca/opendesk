# OpenDesk Environment Variables
# Copy to .env and adjust as needed.
# Dev defaults work out of the box with `docker compose up -d`.

# ── Server ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed CORS origins (empty = allow all in dev)
CORS_ORIGINS=

# ── Auth ─────────────────────────────────────────────────────────────
# "dev" bypasses auth entirely (forbidden in production). "oidc" for real auth.
AUTH_MODE=dev
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
# Only needed in production OIDC mode:
# OIDC_CLIENT_SECRET=changeme
# SESSION_SECRET=changeme

# ── PostgreSQL ───────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=opendesk
PG_USER=opendesk
PG_PASSWORD=opendesk_dev
PG_MAX_CONNECTIONS=10

# ── S3 / MinIO ──────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=opendesk
S3_SECRET_KEY=opendesk_dev
S3_BUCKET=opendesk
S3_REGION=us-east-1

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=opendesk:
REDIS_MAX_RETRIES=20
REDIS_CONNECT_TIMEOUT_MS=5000
# Used by docker-compose.prod.yml for the Redis requirepass flag:
# REDIS_PASSWORD=changeme

# ── Collabora / LibreOffice ─────────────────────────────────────────
COLLABORA_URL=http://localhost:9980
COLLABORA_TIMEOUT_MS=30000
FLUSH_TIMEOUT_MS=10000

# ── Audit ────────────────────────────────────────────────────────────
# Min 32 chars. MUST be changed in production.
OPENDESK_AUDIT_HMAC_SECRET=dev-audit-secret-must-change-in-prod-32chars

# ── Logging ──────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ── Observability ────────────────────────────────────────────────────
OBSERVABILITY_ENABLED=true
OBSERVABILITY_SAMPLE_RATE=1
OBSERVABILITY_HEALTH_INTERVAL_MS=60000

# ── Local AI (BYOM) ─────────────────────────────────────────────────
AI_ENABLED=false
AI_OLLAMA_URL=http://localhost:11434
AI_EMBEDDING_MODEL=all-minilm
AI_CHAT_MODEL=llama3.2
AI_CHUNK_SIZE=512
AI_CHUNK_OVERLAP=64
AI_EMBEDDING_DIMENSIONS=384

# ── Federation ───────────────────────────────────────────────────────
FEDERATION_ENABLED=false
FEDERATION_INSTANCE_ID=
FEDERATION_PRIVATE_KEY=
FEDERATION_PUBLIC_KEY=
# Allow peers whose hostname resolves to RFC1918 / IPv6 ULA. Required
# for self-hosted instances on a LAN. Loopback and link-local are
# always forbidden regardless. See issue #131.
OPENDESK_FEDERATION_ALLOW_PRIVATE=false
# Allow http:// and ws:// peer URLs (off by default; production
# federation traffic must be encrypted).
OPENDESK_FEDERATION_ALLOW_INSECURE_SCHEMES=false

# ── Integration tests (issue #126/127) ──────────────────────────────
# Set OPENDESK_TEST_PG=1 to opt in to integration tests that hit a
# real Postgres. Without this, the integration suites skip cleanly so
# `npm test` works on machines without docker. Defaults below match
# docker-compose.yml.
# OPENDESK_TEST_PG=1
# OPENDESK_TEST_PG_HOST=localhost
# OPENDESK_TEST_PG_PORT=5433
# OPENDESK_TEST_PG_DATABASE=opendesk
# OPENDESK_TEST_PG_USER=opendesk
# OPENDESK_TEST_PG_PASSWORD=opendesk_dev

# ── Nginx (production overlay only) ─────────────────────────────────
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
# Contract: contracts/config/rules.md
# OpenDesk production environment variables
# Copy to .env and fill in all values before deploying.
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env up -d
# --- Postgres ---
PG_PASSWORD=CHANGE_ME_pg_strong_password
# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_strong_password
# --- MinIO / S3 ---
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key
# --- Auth ---
AUTH_MODE=oidc
SESSION_SECRET=CHANGE_ME_64_char_random_string
OIDC_ISSUER=https://your-idp.example.com
OIDC_CLIENT_ID=CHANGE_ME_client_id
OIDC_CLIENT_SECRET=CHANGE_ME_client_secret
# --- Nginx (optional, defaults shown) ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
