# Example nginx config for deployments where nginx itself terminates TLS.
# Copy to nginx.conf and update cert paths before use.
#
# Requirements:
#   - TLS 1.2+ (Safari 12+ requires TLS 1.2; TLS 1.0/1.1 must be disabled)
#   - Certificate and key mounted at the paths below
#   - Redirect HTTP → HTTPS so assets are never served over plaintext
#
# In docker-compose.prod.yml, mount certs:
#   volumes:
#     - ./certs/cert.pem:/etc/ssl/certs/opendesk.pem:ro
#     - ./certs/key.pem:/etc/ssl/private/opendesk.key:ro
#     - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro

# Redirect all HTTP to HTTPS
server {
    listen 80;
    server_name _;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name _;

    ssl_certificate     /etc/ssl/certs/opendesk.pem;
    ssl_certificate_key /etc/ssl/private/opendesk.key;

    # TLS 1.2+ only — TLS 1.0 and 1.1 are broken and rejected by Safari 12+
    ssl_protocols TLSv1.2 TLSv1.3;

    # Strong cipher suites compatible with Safari, Chrome, and Firefox
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256;
    ssl_prefer_server_ciphers off;

    # Session resumption
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;

    # OCSP stapling (requires a CA-signed cert, not self-signed)
    # ssl_stapling on;
    # ssl_stapling_verify on;

    client_max_body_size 50m;

    # Security headers (CSP and HSTS are handled by Helmet in Express)
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # HSTS — tell browsers to always use HTTPS for this origin.
    # max-age=63072000 = 2 years. Only add this header once TLS is stable.
    add_header Strict-Transport-Security "max-age=63072000" always;

    gzip on;
    gzip_types text/html text/css application/javascript application/json;
    gzip_min_length 256;

    location / {
        proxy_pass http://opendesk:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    location /collab {
        proxy_pass http://opendesk:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 3600s;
    }
}
