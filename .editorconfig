# OpenDesk editor configuration — keeps formatting consistent across
# editors so dev-to-CI formatting failures stop being a class of bug.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown often relies on trailing spaces for hard line breaks; don't
# strip them.
[*.md]
trim_trailing_whitespace = false

# Makefile has hard requirements on tabs.
[Makefile]
indent_style = tab

# Shell scripts and YAML keep the 2-space default.
[*.{sh,yml,yaml}]
indent_size = 2
