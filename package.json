{
  "name": "opendesk",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Sovereign, agent-first open office suite",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "npm run build:frontend && npm run check",
    "build:frontend": "node scripts/build-frontend.js",
    "check": "tsc --noEmit",
    "start": "npm run build:frontend && node --import=tsx server.ts",
    "dev": "npm run build:frontend && node scripts/watch-frontend.mjs & node --import=tsx --watch server.ts",
    "watch:frontend": "node scripts/watch-frontend.mjs",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest",
    "test:e2e": "npx playwright test",
    "stress": "npx tsx stress/collab-stress.ts",
    "lint": "eslint modules/",
    "deliberate": "./scripts/deliberate.sh",
    "audit": "./scripts/audit.sh",
    "audit:security": "./scripts/audit.sh --security",
    "roadmap": "./scripts/roadmap.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@hocuspocus/provider": "^3.4.4",
    "@hocuspocus/server": "^3.4.4",
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-code-block-lowlight": "^3.22.2",
    "@tiptap/extension-collaboration": "^3.22.2",
    "@tiptap/extension-collaboration-cursor": "^3.0.0",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-mention": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@tiptap/y-tiptap": "^3.0.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "lowlight": "^3.3.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "rate-limit-redis": "^4.3.1",
    "tsx": "^4.21.0",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.6.0",
    "supertest": "^7.2.2",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
