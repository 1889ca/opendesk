{
  "name": "opendesk",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Sovereign, agent-first open office suite",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "npm run build:frontend && npm run check",
    "build:frontend": "esbuild modules/app/internal/editor.ts --bundle --outfile=modules/app/internal/public/editor.bundle.js --format=esm --target=es2022 --minify",
    "check": "tsc --noEmit",
    "start": "npm run build:frontend && node --import=tsx server.ts",
    "dev": "npm run build:frontend && node --import=tsx --watch server.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest",
    "lint": "eslint modules/",
    "deliberate": "./scripts/deliberate.sh",
    "audit": "./scripts/audit.sh",
    "audit:security": "./scripts/audit.sh --security",
    "roadmap": "./scripts/roadmap.sh"
  },
  "dependencies": {
    "@hocuspocus/provider": "^3.4.4",
    "@hocuspocus/server": "^3.4.4",
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-collaboration": "^3.22.2",
    "@tiptap/extension-collaboration-cursor": "^3.0.0",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@tiptap/y-tiptap": "^3.0.2",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
